# Deribit Storage - Environment Variables Example
# Copy this file to .env and fill in the actual values

# ========== APPLICATION ==========
APP_ENV=development
DEBUG=true

# ========== API SERVER ==========
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ========== AUTHENTICATION ==========
# Client credentials for API access
API_CLIENT_ID=your_client_id_here
API_CLIENT_SECRET=your_client_secret_here
API_RATE_LIMIT_PER_MINUTE=60

# ========== DATABASE ==========
# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://deribit_user:deribit_password@postgres:5432/deribit_storage
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ========== REDIS (for Celery) ==========
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20

# ========== DERIBIT API ==========
DERIBIT_BASE_URL=https://www.deribit.com/api/v2
DERIBIT_REQUEST_TIMEOUT=30
DERIBIT_MAX_RETRIES=3
DERIBIT_RETRY_DELAY_BASE=4

# ========== LOGGING ==========
LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_FILE=/var/log/deribit_storage.log  # Uncomment for file logging

# ========== CELERY ==========
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true