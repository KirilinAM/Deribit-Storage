# Deribit Storage - Environment Variables Example
# Copy this file to .env and fill in the actual values

# ========== APPLICATION ==========
DEBUG=true

# ========== DATABASE ==========
# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://deribit_user:deribit_password@postgres:5432/deribit_storage
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false


# ========== AUTHENTICATION ==========
# Client credentials for API access
API_CLIENT_ID=your_client_id_here
API_CLIENT_SECRET=your_client_secret_here
